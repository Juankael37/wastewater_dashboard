# Copy to scripts/smoke.env (gitignored) for full Worker + Supabase smoke test.
# Use an operator or admin account (viewer cannot insert measurements).

WORKER_URL=https://wastewater-api.juankael37.workers.dev

# Baseline auth checks (login + /auth/me + core reads + optional POST /measurements)
SMOKE_EMAIL=you@example.com
SMOKE_PASSWORD=your-password

# Optional RBAC checks for PATCH /alerts/:id/resolve
SMOKE_OPERATOR_EMAIL=operator@example.com
SMOKE_OPERATOR_PASSWORD=operator-password
SMOKE_ADMIN_EMAIL=admin@example.com
SMOKE_ADMIN_PASSWORD=admin-password

# Optional: set to 1 to skip posting measurement in smoke script
# SKIP_POST_MEASUREMENT=1
