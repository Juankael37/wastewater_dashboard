# Non-secret deployment identifiers — copy values into docs, Wrangler, and Vite env as needed.
# Do not put API keys or passwords in this file.

# Flask runtime environment
# Use APP_ENV=production in deployed environments.
APP_ENV=development

# Flask secret key for session signing (required in production/staging)
FLASK_SECRET_KEY=

# Optional one-time bootstrap user creation on app startup.
# Keep disabled by default. If enabled, set both username and password.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=

# Comma-separated CORS allowlist for Flask API (no wildcard in production).
FLASK_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase project URL host segment (from Project Settings → General → Reference ID)
SUPABASE_PROJECT_REF=pkyazsrbhjtxbpwsxbwe
SUPABASE_URL=https://pkyazsrbhjtxbpwsxbwe.supabase.co

# Cloudflare Worker (after wrangler deploy)
CLOUDFLARE_WORKER_URL=https://wastewater-api.juankael37.workers.dev

# Cloudflare Pages PWA host (must match ALLOWED_ORIGINS in api/wrangler.toml)
CLOUDFLARE_PAGES_URL=https://wastewaterinput.pages.dev

# Google Sheets (same ID in Worker var GOOGLE_SHEETS_ID — not secret)
# URL form: https://docs.google.com/spreadsheets/d/<GOOGLE_SHEETS_ID>/edit
GOOGLE_SHEETS_ID=
