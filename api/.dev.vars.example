# Copy to .dev.vars (gitignored) for `wrangler dev`
SUPABASE_URL=https://pkyazsrbhjtxbpwsxbwe.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Required for Worker /api/users/:id delete parity (admin delete via Supabase Admin API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ALLOWED_ORIGINS=LAN_DEV_ORIGINS,http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,https://wastewaterinput.pages.dev

# Optional — Google Sheets backup (append row on each POST /measurements)
# From sheet URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEETS_ID=your-spreadsheet-id
# Paste full service account JSON on ONE line, or use: wrangler secret put GOOGLE_SERVICE_ACCOUNT_JSON
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Optional if tab is not "Sheet1" or range differs (default Sheet1!A:M)
# GOOGLE_SHEETS_RANGE=Sheet1!A:M
